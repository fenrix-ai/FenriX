rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(playerId) {
      return signedIn() && request.auth.uid == playerId;
    }

    // ─────────────────────────────────────────────────────────
    // isProfessor — BE-22: checks the custom claim set by
    // the set-professor-claim admin script (BE-18).
    // ─────────────────────────────────────────────────────────
    function isProfessor() {
      return signedIn() && request.auth.token.professor == true;
    }

    // ─────────────────────────────────────────────────────────
    // isGameProfessor — allows the actual game's professor (the
    // UID written to game.professorUid / professorId at creation)
    // to read game-scoped admin docs without the global custom
    // claim. Removes a deploy dependency on the BE-18 set-claim
    // script for live gameplay.
    // ─────────────────────────────────────────────────────────
    function isGameProfessor(gameId) {
      return signedIn()
        && exists(/databases/$(database)/documents/games/$(gameId))
        && (
          get(/databases/$(database)/documents/games/$(gameId)).data.professorUid
            == request.auth.uid
          || get(/databases/$(database)/documents/games/$(gameId)).data.professorId
            == request.auth.uid
        );
    }

    // ─────────────────────────────────────────────────────────
    // /games/{gameId}
    // Players can read game state to track phase, round, timers.
    // Only Cloud Functions can write (phase transitions, score updates).
    // ─────────────────────────────────────────────────────────
    match /games/{gameId} {
      allow read: if signedIn();
      allow write: if false;

      // ─────────────────────────────────────────────────────
      // /games/{gameId}/config/params
      // Read-only for all authenticated users.
      // ─────────────────────────────────────────────────────
      match /config/{doc} {
        allow read: if signedIn();
        allow write: if false;
      }

      // ─────────────────────────────────────────────────────
      // /games/{gameId}/marketInsights/{doc}
      // Market-insight emails generated by Cloud Functions at the start of
      // each round's email phase. Read-only for all authenticated players.
      // Written exclusively by Cloud Functions (startGame + advanceGamePhase).
      // ─────────────────────────────────────────────────────
      match /marketInsights/{doc} {
        allow read: if signedIn();
        allow write: if false;
      }

      // ─────────────────────────────────────────────────────
      // /games/{gameId}/players/{playerId}
      // Players can only read/write their own document.
      // Writes are restricted to decision/bid fields only —
      // financial state (budgetCurrent, cumulativeRevenue, lastRoundResult)
      // is owned by Cloud Functions and cannot be overwritten client-side.
      // ─────────────────────────────────────────────────────
      match /players/{playerId} {
        allow read: if isOwner(playerId);
        allow create: if false;
        allow update: if isOwner(playerId)
          && request.resource.data.diff(resource.data)
               .changedKeys()
               .hasOnly(["displayName", "pendingDecision", "pendingBids"]);

        // Immutable decision snapshots are written by Cloud Functions after
        // server-side validation in submitDecision.
        match /decisions/{roundId} {
          allow read: if isOwner(playerId);
          allow create: if false;
          allow update: if false;
          allow delete: if false;
        }

        // Round results are written exclusively by Cloud Functions.
        match /rounds/{roundId} {
          allow read: if isOwner(playerId) || isGameProfessor(gameId);
          allow write: if false;
        }

        // Email phase data drops are written exclusively by Cloud Functions.
        match /emails/{emailId} {
          allow read: if isOwner(playerId);
          allow write: if false;
        }
      }

      // ─────────────────────────────────────────────────────
      // /games/{gameId}/rounds/{roundId}
      // Aggregate round data — readable by all players (e.g. for professor
      // dashboard and class-wide results view), written only by Cloud Functions.
      // ─────────────────────────────────────────────────────
      match /rounds/{roundId} {
        allow read: if signedIn();
        allow write: if false;

        // ───────────────────────────────────────────────────
        // /games/{gameId}/rounds/{roundId}/topBidsShards/{shardIdx}
        // Sharded live-bid intake. Each shard holds the per-team bid
        // amounts for the teams hashed to that shard. Server-only:
        // exposing the per-team breakdown would defeat the sealed-bid
        // design. The aggregated leader/top values are mirrored to
        // `rounds/{roundId}.topBids` + `topBidsLeader` by the
        // `onTopBidsShardWritten` trigger and read from there by the FE.
        // ───────────────────────────────────────────────────
        match /topBidsShards/{shardIdx} {
          allow read: if false;
          allow write: if false;
        }
      }

      // ─────────────────────────────────────────────────────
      // /games/{gameId}/leaderboard/{leaderboardId}
      // Read-only for all authenticated players.
      // Rewritten by Cloud Function after each round simulation.
      // ─────────────────────────────────────────────────────
      match /leaderboard/{leaderboardId} {
        allow read: if signedIn();
        allow write: if false;
      }

      // ─────────────────────────────────────────────────────
      // /games/{gameId}/roster/{playerId}
      // Public-safe lobby roster — { uid, displayName, bakeryName, joinedAt,
      // updatedAt }. Readable (get + list) by any signed-in user so the lobby
      // can subscribe to the full player list via onSnapshot. Written only by
      // the joinGame callable. Intentionally excludes financial state (budget,
      // revenue) which remains in /players/{playerId} and is readable only by
      // the owner.
      // ─────────────────────────────────────────────────────
      match /roster/{playerId} {
        allow read: if signedIn();
        allow write: if false;
      }

      // ─────────────────────────────────────────────────────
      // /games/{gameId}/csvRows/{playerId}/rounds/{roundId}
      // Players can only read their own CSV rows.
      // Written exclusively by Cloud Functions.
      // ─────────────────────────────────────────────────────
      match /csvRows/{playerId}/rounds/{roundId} {
        allow read: if isOwner(playerId);
        allow write: if false;
      }

      // ─────────────────────────────────────────────────────
      // /games/{gameId}/teams/{teamId}
      // Team metadata and roleAssignments map. Readable by any
      // signed-in player so the lobby/game UI can display team
      // info. Written exclusively by Cloud Functions
      // (updateTeamName, setTeamRole).
      // ─────────────────────────────────────────────────────
      match /teams/{teamId} {
        allow read: if signedIn();
        allow write: if false;
      }

      // ─────────────────────────────────────────────────────
      // /games/{gameId}/submissions/{doc}
      // BE-22: Professor submission-state mirror. Written
      // exclusively by Cloud Functions (submitDecision,
      // submitBids, continueFromRoster). Readable only by
      // the professor (custom claim: professor == true) or
      // the game's professor UID. Contains per-player
      // submission status, displayName, role, and timestamps —
      // do NOT widen this rule. Player-facing UIs that need a
      // submission count should read /submissionCounts/{doc}
      // (count-only mirror written alongside this doc).
      // Doc IDs follow the pattern "round_{N}_{phase}".
      // ─────────────────────────────────────────────────────
      match /submissions/{doc} {
        allow read: if isProfessor() || isGameProfessor(gameId);
        allow write: if false;

        // ───────────────────────────────────────────────────
        // /games/{gameId}/submissions/{doc}/shards/{shardIdx}
        // Sharded intake for the submissions mirror — server-only.
        // The aggregated public view lives one level up at
        // `submissions/{doc}` and is maintained by the
        // `onSubmissionShardWritten` trigger from the shard data.
        // ───────────────────────────────────────────────────
        match /shards/{shardIdx} {
          allow read: if false;
          allow write: if false;
        }
      }

      // ─────────────────────────────────────────────────────
      // /games/{gameId}/submissionCounts/{doc}
      // Public-safe count mirror for /submissions. Schema:
      //   { count: number, updatedAt: Timestamp }
      // Written exclusively by Cloud Functions in lockstep
      // with /submissions. Readable by any signed-in player so
      // the SubmissionLock footer can show "X / Y submitted"
      // without leaking opposing-team submission identities.
      // Doc IDs follow the pattern "round_{N}_{phase}".
      // ─────────────────────────────────────────────────────
      match /submissionCounts/{doc} {
        allow read: if signedIn();
        allow write: if false;
      }
    }
  }
}
